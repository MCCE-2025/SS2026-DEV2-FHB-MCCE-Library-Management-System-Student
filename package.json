{
  "name": "library-management-api",
  "version": "1.0.0",
  "description": "Library Management System — FHB Test Automation Course System Under Test",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node seed.js",
    "test": "npm run test:unit && npm run test:api && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:unit:coverage": "vitest run --coverage tests/unit",
    "test:unit:ci": "vitest run --coverage tests/unit --reporter=default --reporter=junit --outputFile=test-results/junit-unit.xml",
    "test:api": "vitest run --config vitest.api.config.js",
    "test:api:watch": "vitest --config vitest.api.config.js",
    "test:api:coverage": "vitest run --config vitest.api.config.js --coverage",
    "test:api:ci": "vitest run --config vitest.api.config.js --coverage --reporter=default --reporter=junit --outputFile=test-results/junit-api.xml",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:integration:watch": "vitest --config vitest.integration.config.js",
    "test:integration:coverage": "vitest run --config vitest.integration.config.js --coverage",
    "test:integration:ci": "vitest run --config vitest.integration.config.js --coverage --reporter=default --reporter=junit --outputFile=test-results/junit-integration.xml",
    "test:coverage": "npm run test:unit:coverage && npm run test:api:coverage && npm run test:integration:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "playwright test"
  },
  "dependencies": {
    "express": "^4.18.3",
    "sql.js": "^1.12.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
